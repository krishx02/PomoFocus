{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@pomofocus/types",
  "sourceRoot": "packages/types/src",
  "projectType": "library",
  "tags": ["type:types", "scope:shared"],
  "targets": {
    "gen": {
      "command": "pnpm run gen:types",
      "options": {
        "cwd": "packages/types"
      }
    },
    "lint": {
      "command": "npx eslint .",
      "options": {
        "cwd": "packages/types"
      }
    },
    "type-check": {
      "command": "tsc -p tsconfig.lib.json --noEmit",
      "options": {
        "cwd": "packages/types"
      }
    }
  }
}
