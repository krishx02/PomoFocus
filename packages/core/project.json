{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@pomofocus/core",
  "sourceRoot": "packages/core/src",
  "projectType": "library",
  "tags": ["type:domain", "scope:shared"],
  "targets": {
    "lint": {
      "command": "npx eslint .",
      "options": {
        "cwd": "packages/core"
      }
    },
    "test": {
      "command": "vitest run --config vitest.config.ts",
      "options": {
        "cwd": "packages/core"
      }
    },
    "type-check": {
      "command": "tsc -p tsconfig.lib.json --noEmit",
      "options": {
        "cwd": "packages/core"
      }
    }
  }
}
