{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(gh *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(pnpm install*)",
      "Bash(pnpm nx*)",
      "Bash(pnpm run*)",
      "Bash(pnpm type-check*)",
      "Bash(npx nx*)",
      "Bash(node *)",
      "Bash(xcodebuild test*)",
      "Bash(xcodebuild build*)",
      "Bash(git rev-parse*)",
      "Bash(mktemp*)",
      "Bash(rm /tmp/*)",
      "Bash(timeout *)"
    ],
    "ask": [
      "Bash(git reset*)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- *)",
      "Bash(rm -rf*)"
    ]
  }
}
