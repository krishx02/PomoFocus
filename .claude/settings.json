{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(gh *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git stash*)",
      "Bash(git show*)",
      "Bash(git merge*)",
      "Bash(git worktree*)",
      "Bash(git rev-parse*)",
      "Bash(git remote*)",
      "Bash(git tag*)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(xcodebuild test*)",
      "Bash(xcodebuild build*)",
      "Bash(maestro *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(test *)",
      "Bash(mkdir *)",
      "Bash(command *)",
      "Bash(which *)",
      "Bash(mktemp*)",
      "Bash(rm /tmp/*)",
      "Bash(timeout *)",
      "Bash(kill %*)",
      "Bash(git rebase*)",
      "Bash(date *)",
      "Bash(grep *)",
      "Bash(sort *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(xargs *)",
      "Bash(wc *)",
      "Bash(tr *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(curl *)",
      "Bash(python3 *)",
      "Bash(cd *)"
    ],
    "ask": [
      "Bash(git reset*)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git clean*)",
      "Bash(git checkout -- *)",
      "Bash(rm -rf*)",
      "Bash(rm -r *)"
    ]
  }
}
