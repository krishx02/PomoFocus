{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@pomofocus/web",
  "sourceRoot": "apps/web",
  "projectType": "application",
  "tags": ["type:app", "scope:web"],
  "targets": {
    "lint": {
      "command": "npx eslint .",
      "options": {
        "cwd": "apps/web"
      }
    },
    "test": {
      "command": "vitest run --config vitest.config.ts",
      "options": {
        "cwd": "apps/web"
      }
    },
    "type-check": {
      "command": "tsc -p tsconfig.json --noEmit",
      "options": {
        "cwd": "apps/web"
      }
    }
  }
}
