# PomoFocus Environment Variables
# Copy this file to .env.local and fill in values.
# See platform-specific .env.example files for details.

# ── Supabase ─────────────────────────────────────────────────────
# Local dev defaults from `supabase start`.
# For production, use values from your Supabase project dashboard.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_PROJECT_ID=your-project-id

# ── Web (apps/web/) ─────────────────────────────────────────────
# Production: set in Vercel dashboard.
# Local dev: set in apps/web/.env.local.
EXPO_PUBLIC_API_URL=http://localhost:8787
